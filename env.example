# Store finder API (recipe-backend). From repo root: npm run recipe-backend
# (first time: cd recipe-backend && npm install). Optional GOOGLE_MAPS_API_KEY in recipe-backend/.env.
# Optional override — on web the app also tries localhost and 127.0.0.1 on port 3000.
# EXPO_PUBLIC_RECIPE_API_URL=http://127.0.0.1:3000

# Use your project URL from Supabase Dashboard → Settings → API (must be https)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-supabase-anon-key-here