GEMINI_API_KEY=your_gemini_api_key_here
PORT=3000

# --- Optional: real store search (Walmart / Kroger / Aldi) via Google ---
# Without this key, the server still runs in DEMO mode (sample pins + OSM geocoding for text queries).
#
# 1. Google Cloud Console → APIs & Services → Enable billing on the project.
# 2. Enable APIs: "Places API" (legacy) and "Geocoding API".
# 3. APIs & Services → Credentials → Create credentials → API key.
# 4. Restrict the key (HTTP referrers for web, or IP for server-only) in production.
# 5. Paste the key below and restart: npm start
GOOGLE_MAPS_API_KEY=
